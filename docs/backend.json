
{
  "entities": {
    "Teacher": {
      "title": "Teacher",
      "type": "object",
      "description": "Perfil do docente autenticado.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["Admin", "Professor"] }
      }
    },
    "Class": {
      "title": "Class",
      "type": "object",
      "description": "Turma vinculada ao professor.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "teacherId": { "type": "string" }
      }
    },
    "Student": {
      "title": "Student",
      "type": "object",
      "description": "Aluno cadastrado em uma subcoleção do professor.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "ra": { "type": "string" },
        "classId": { "type": "string" },
        "teacherId": { "type": "string" },
        "photo": { "type": "string", "description": "Base64 da thumbnail (máx 200x200)" }
      }
    },
    "AttendanceRecord": {
      "title": "AttendanceRecord",
      "type": "object",
      "description": "Registro diário de frequência.",
      "properties": {
        "id": { "type": "string" },
        "studentId": { "type": "string" },
        "classId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "status": { "type": "string" },
        "recordedByTeacherId": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password", "google"]
  },
  "firestore": {
    "/teachers/{teacherId}": {
      "schema": { "$ref": "#/backend/entities/Teacher" },
      "description": "Root docente."
    },
    "/teachers/{teacherId}/classes/{classId}": {
      "schema": { "$ref": "#/backend/entities/Class" },
      "description": "Turmas do docente."
    },
    "/teachers/{teacherId}/students/{studentId}": {
      "schema": { "$ref": "#/backend/entities/Student" },
      "description": "Estudantes vinculados ao docente (independente da classe)."
    },
    "/teachers/{teacherId}/attendanceRecords/{recordId}": {
      "schema": { "$ref": "#/backend/entities/AttendanceRecord" },
      "description": "Registros de frequência."
    }
  }
}
