
{
  "entities": {
    "Teacher": {
      "title": "Teacher",
      "type": "object",
      "description": "Perfil do docente autenticado.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["Admin", "Professor"] },
        "assignments": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "classId": { "type": "string" },
              "className": { "type": "string" },
              "subject": { "type": "string" },
              "dayOfWeek": { "type": "string" },
              "lessonNumber": { "type": "string" }
            }
          }
        }
      }
    },
    "Class": {
      "title": "Class",
      "type": "object",
      "description": "Turma da unidade escolar.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "subject": { "type": "string" },
        "teacherId": { "type": "string" }
      }
    },
    "Student": {
      "title": "Student",
      "type": "object",
      "description": "Estudante matriculado na unidade.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "ra": { "type": "string" },
        "raDigit": { "type": "string" },
        "classId": { "type": "string" },
        "photo": { "type": "string" },
        "tutor": { "type": "string", "description": "Nome do tutor ou responsável pelo aluno." }
      }
    },
    "AttendanceRecord": {
      "title": "AttendanceRecord",
      "type": "object",
      "description": "Registro diário de frequência.",
      "properties": {
        "id": { "type": "string" },
        "studentId": { "type": "string" },
        "classId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "status": { "type": "string" },
        "teacherId": { "type": "string" },
        "bimestre": { "type": "string" }
      }
    },
    "StudentObservation": {
      "title": "StudentObservation",
      "type": "object",
      "description": "Observações pedagógicas sobre o aluno.",
      "properties": {
        "id": { "type": "string" },
        "studentId": { "type": "string" },
        "teacherId": { "type": "string" },
        "classId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "content": { "type": "string" },
        "bimestre": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password", "google"]
  },
  "firestore": {
    "/teachers/{teacherId}": {
      "schema": { "$ref": "#/backend/entities/Teacher" },
      "description": "Perfis de usuários."
    },
    "/classes/{classId}": {
      "schema": { "$ref": "#/backend/entities/Class" },
      "description": "Coleção global de turmas."
    },
    "/students/{studentId}": {
      "schema": { "$ref": "#/backend/entities/Student" },
      "description": "Coleção global de alunos."
    },
    "/attendanceRecords/{recordId}": {
      "schema": { "$ref": "#/backend/entities/AttendanceRecord" },
      "description": "Coleção global de frequências."
    },
    "/studentObservations/{obsId}": {
      "schema": { "$ref": "#/backend/entities/StudentObservation" },
      "description": "Coleção global de observações pedagógicas."
    },
    "/lessons/{lessonId}": {
      "schema": { "type": "object" },
      "description": "Coleção global de registros de aula (conteúdo)."
    },
    "/assessments/{assessmentId}": {
      "schema": { "type": "object" },
      "description": "Coleção global de avaliações."
    }
  }
}
