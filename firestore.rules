
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid == "U3vapjp9K2NqRpYdp2ZzJ8vfZsm1" || 
        get(/databases/$(database)/documents/teachers/$(request.auth.uid)).data.role == "Admin"
      );
    }

    // --- CONFIGURAÇÕES GLOBAIS ---
    match /settings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // --- PROFESSORES ---
    match /teachers/{teacherId} {
      allow get: if isSignedIn();
      // Permite listagem restrita para o handshake de login/atribuição
      allow list: if isSignedIn() && (isAdmin() || request.query.limit <= 5);
      allow write: if isAdmin() || (isSignedIn() && request.auth.uid == teacherId);
    }

    // --- TURMAS (GLOBAL) ---
    match /classes/{classId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // --- ESTUDANTES (GLOBAL) ---
    match /students/{studentId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && request.auth.uid == resource.data.teacherId);
      allow delete: if isAdmin() || (isSignedIn() && request.auth.uid == resource.data.teacherId);
    }

    // --- FREQUÊNCIA (GLOBAL) ---
    match /attendanceRecords/{recordId} {
      allow read: if isSignedIn();
      // Permite criar se estiver logado, e atualizar/deletar se for o dono ou admin
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && request.auth.uid == resource.data.teacherId);
      allow delete: if isAdmin() || (isSignedIn() && request.auth.uid == resource.data.teacherId);
    }

    // --- REGISTROS DE AULA (GLOBAL) ---
    match /lessons/{lessonId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // --- AVALIAÇÕES (GLOBAL) ---
    match /assessments/{assessmentId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
  }
}
