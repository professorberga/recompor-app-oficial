rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid == "U3vapjp9K2NqRpYdp2ZzJ8vfZsm1" || 
        get(/databases/$(database)/documents/teachers/$(request.auth.uid)).data.role == "Admin"
      );
    }

    // --- CONFIGURAÇÕES GLOBAIS ---
    match /settings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // --- PROFESSORES ---
    match /teachers/{teacherId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || (isSignedIn() && (
        request.auth.uid == teacherId || 
        (resource != null && resource.data.email == request.auth.token.email) ||
        (request.resource != null && request.resource.data.email == request.auth.token.email)
      ));
    }

    // --- TURMAS (GLOBAL) ---
    match /classes/{classId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // --- ESTUDANTES (GLOBAL) ---
    match /students/{studentId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && (request.auth.uid == resource.data.teacherId || request.auth.uid == resource.data.teacherUid));
      allow delete: if isAdmin() || (isSignedIn() && (request.auth.uid == resource.data.teacherId || request.auth.uid == resource.data.teacherUid));
    }

    // --- FREQUÊNCIA (GLOBAL) ---
    match /attendanceRecords/{recordId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && request.auth.uid == resource.data.teacherId);
      allow delete: if isAdmin() || (isSignedIn() && request.auth.uid == resource.data.teacherId);
    }

    // --- OBSERVACÕES PEDAGÓGICAS ---
    match /studentObservations/{obsId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // --- REGISTROS DE AULA (GLOBAL) ---
    match /lessons/{lessonId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // --- AVALIAÇÕES (GLOBAL) ---
    match /assessments/{assessmentId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
  }
}