
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * MONITOR DO BEEM - SECURITY RULES
     * 
     * Estrutura Hierárquica: /teachers/{teacherId}/...
     * Enforce: isOwner(teacherId) para todas as subcoleções.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    // --- COLEÇÃO DE PROFESSORES ---
    match /teachers/{teacherId} {
      allow get, list: if isOwner(teacherId);
      allow create: if isOwner(teacherId);
      allow update: if isExistingOwner(teacherId);
      allow delete: if isExistingOwner(teacherId);

      // --- SUBCOLEÇÃO DE TURMAS ---
      match /classes/{classId} {
        allow get, list: if isOwner(teacherId);
        allow create: if isOwner(teacherId) && request.resource.data.teacherId == teacherId;
        allow update: if isExistingOwner(teacherId) && request.resource.data.teacherId == resource.data.teacherId;
        allow delete: if isExistingOwner(teacherId);
      }

      // --- SUBCOLEÇÃO DE ESTUDANTES (FLAT HIERARCHY) ---
      match /students/{studentId} {
        allow get, list: if isOwner(teacherId);
        allow create: if isOwner(teacherId) && request.resource.data.teacherId == teacherId;
        allow update: if isExistingOwner(teacherId) && request.resource.data.teacherId == resource.data.teacherId;
        allow delete: if isExistingOwner(teacherId);
      }

      // --- SUBCOLEÇÃO DE AVALIAÇÕES ---
      match /assessments/{assessmentId} {
        allow get, list: if isOwner(teacherId);
        allow create: if isOwner(teacherId) && request.resource.data.teacherId == teacherId;
        allow update: if isExistingOwner(teacherId) && request.resource.data.teacherId == resource.data.teacherId;
        allow delete: if isExistingOwner(teacherId);
      }

      // --- SUBCOLEÇÃO DE REGISTROS DE CHAMADA ---
      match /attendanceRecords/{attendanceRecordId} {
        allow get, list: if isOwner(teacherId);
        allow create: if isOwner(teacherId) && request.resource.data.recordedByTeacherId == teacherId;
        allow update: if isExistingOwner(teacherId) && request.resource.data.recordedByTeacherId == resource.data.recordedByTeacherId;
        allow delete: if isExistingOwner(teacherId);
      }

      // --- SUBCOLEÇÃO DE OBSERVAÇÕES ---
      match /studentObservations/{studentObservationId} {
        allow get, list: if isOwner(teacherId);
        allow create: if isOwner(teacherId) && request.resource.data.teacherId == teacherId;
        allow update: if isExistingOwner(teacherId) && request.resource.data.teacherId == resource.data.teacherId;
        allow delete: if isExistingOwner(teacherId);
      }

      // --- SUBCOLEÇÃO DE LIÇÕES/CONTEÚDOS ---
      match /lessons/{lessonId} {
        allow get, list: if isOwner(teacherId);
        allow create: if isOwner(teacherId) && request.resource.data.teacherId == teacherId;
        allow update: if isExistingOwner(teacherId) && request.resource.data.teacherId == resource.data.teacherId;
        allow delete: if isExistingOwner(teacherId);
      }
    }

    // --- COLEÇÃO GLOBAL DE COMPETÊNCIAS ---
    match /competencies/{competencyId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if false;
    }
  }
}
