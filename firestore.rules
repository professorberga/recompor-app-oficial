
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid == "U3vapjp9K2NqRpYdp2ZzJ8vfZsm1" || 
        get(/databases/$(database)/documents/teachers/$(request.auth.uid)).data.role == "Admin"
      );
    }

    // --- CONFIGURAÇÕES GLOBAIS ---
    match /settings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // --- PROFESSORES (IDENTIDADE E MIGRAÇÃO) ---
    match /teachers/{teacherId} {
      // Permite leitura se o ID for o UID OU se o e-mail no documento for o e-mail do token
      // Isso é vital para o código de migração conseguir ler o perfil antigo (ID=e-mail/RA)
      allow get: if isSignedIn() && (
        request.auth.uid == teacherId || 
        resource.data.email == request.auth.token.email
      );
      // Permite listagem via query de e-mail para o próprio usuário ou Admin
      allow list: if isSignedIn() && (
        isAdmin() || 
        (request.auth.token.email != null && resource.data.email == request.auth.token.email)
      );
      // Permite escrita se for Admin ou se o e-mail do documento corresponder ao token
      // O campo email deve ser soberano para permitir a migração (criação do novo e delete do antigo)
      allow write: if isAdmin() || (isSignedIn() && (
        request.auth.uid == teacherId || 
        (resource != null && resource.data.email == request.auth.token.email) ||
        (request.resource != null && request.resource.data.email == request.auth.token.email)
      ));
    }

    // --- TURMAS (GLOBAL) ---
    match /classes/{classId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // --- ESTUDANTES (GLOBAL) ---
    match /students/{studentId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && (request.auth.uid == resource.data.teacherId || request.auth.uid == resource.data.teacherUid));
      allow delete: if isAdmin() || (isSignedIn() && (request.auth.uid == resource.data.teacherId || request.auth.uid == resource.data.teacherUid));
    }

    // --- FREQUÊNCIA (GLOBAL) ---
    match /attendanceRecords/{recordId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && request.auth.uid == resource.data.teacherId);
      allow delete: if isAdmin() || (isSignedIn() && request.auth.uid == resource.data.teacherId);
    }

    // --- REGISTROS DE AULA (GLOBAL) ---
    match /lessons/{lessonId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // --- AVALIAÇÕES (GLOBAL) ---
    match /assessments/{assessmentId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
  }
}
