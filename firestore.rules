
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * RECOMPOR+ SECURITY RULES
     * 
     * Estrutura: /teachers/{teacherId}/...
     * Enforce: isOwner(teacherId) para professores e bypass total para Admin.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    // UID do Administrador Master (Berga)
    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid == "U3vapjp9K2NqRpYdp2ZzJ8vfZsm1" || 
        get(/databases/$(database)/documents/teachers/$(request.auth.uid)).data.role == "Admin"
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return resource != null && (isOwner(userId) || isAdmin());
    }

    // --- COLEÇÃO DE PROFESSORES ---
    match /teachers/{teacherId} {
      // get: O próprio ou Admin. list: Somente Admin.
      allow get: if isOwner(teacherId) || isAdmin();
      allow list: if isAdmin(); 
      allow create: if isOwner(teacherId) || isAdmin();
      allow update: if isOwner(teacherId) || isAdmin();
      allow delete: if isAdmin();

      // --- SUBCOLEÇÕES (Classes, Students, Records, Lessons, Assessments) ---
      // Todas seguem a lógica: o dono do nó raiz (teacherId) ou o Admin acessam tudo abaixo.
      match /{allSubcollections=**} {
        allow read, write: if isOwner(teacherId) || isAdmin();
      }
    }

    // --- COLEÇÃO GLOBAL DE CLASSES (Opcional, se houver busca fora do nó teacher) ---
    match /classes/{classId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
